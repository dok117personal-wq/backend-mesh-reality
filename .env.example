PORT=3002
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Use pooler (Session mode, port 6543) if direct (5432) is unreachable (e.g. P1001).
# Add ?sslmode=require&connect_timeout=30 if you still get P1001.
# Prisma appends pgbouncer=true automatically so prepared statements work with the pooler.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&connect_timeout=30

CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Auth (session cookie and OAuth redirect). Google/Apple OAuth is via Supabase only; configure providers in Supabase Dashboard.
FRONTEND_URL=http://localhost:3000
SESSION_COOKIE_NAME=session

# For phone OTP (optional): Supabase anon key so backend can call /auth/v1/otp and /auth/v1/verify
SUPABASE_ANON_KEY=your-anon-key

# Swift Photogrammetry API (for generationType "images"). Must be running (e.g. swift run PhotogrammetryAPI).
SWIFT_API_URL=http://127.0.0.1:8080

# Cloudflare R2 (optional). When set, backend uploads input images to R2 and Swift processes from URLs.
# Use same bucket as Swift or a separate one. Public URL for downloads (e.g. https://pub-xxx.r2.dev).
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=3dgeneration
CLOUDFLARE_R2_PUBLIC_URL=
